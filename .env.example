# Supabase Postgres connection string.
# Use the pooled connection string for Vercel, and DIRECT_URL for migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# OpenAI summary generation.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Public app URL used by metadata, sitemap, and canonical URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Protect the Vercel Cron endpoint.
CRON_SECRET="change-me"

# Optional tuning.
INGEST_LIMIT_PER_SOURCE="12"
DUPLICATE_TITLE_THRESHOLD="0.88"
DUPLICATE_EMBEDDING_THRESHOLD="0.90"
